# Runtime settings for docker-compose.yml
KAGI_API_KEY=replace-with-your-kagi-api-key
KAGI_SUMMARIZER_ENGINE=cecil

# MCP network transport settings
MCP_TRANSPORT=streamable-http
MCP_PATH=/mcp
MCP_PORT=8000
MCP_HOST=0.0.0.0

# Build/publish convenience values
KAGIMCP_REF=v0.1.4
GHCR_OWNER=your-github-org-or-user
IMAGE_TAG=dev
